generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Settings {
  id              Int      @id @default(autoincrement())
  kioskId         String   @unique
  kioskName       String
  location        String
  carPrice        Decimal  @db.Decimal(10, 2)
  motorcyclePrice Decimal  @db.Decimal(10, 2)
  ebikePrice      Decimal  @db.Decimal(10, 2)
  openTime        String
  closeTime       String
  receiptHeader   String
  receiptFooter   String
  systemVersion   String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Admin {
  id           String   @id
  username     String   @unique
  passwordHash String
  displayName  String
  role         String
  initials     String
  createdAt    DateTime
  lastLogin    DateTime?
}

model Vehicle {
  id        String   @id
  type      String
  label     String
  sub       String
  priceKey  String
  color     String
  icon      String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Transaction {
  id            String   @id
  type          String
  amount        Decimal  @db.Decimal(10, 2)
  timestamp     DateTime
  status        String
  kioskId       String
  controlNumber String   @unique
  createdAt     DateTime @default(now())

  @@index([timestamp])
  @@index([type])
}

model Expense {
  id          String   @id
  label       String
  amount      Decimal  @db.Decimal(10, 2)
  date        DateTime
  category    String
  description String
  createdAt   DateTime @default(now())

  @@index([date])
  @@index([category])
}
